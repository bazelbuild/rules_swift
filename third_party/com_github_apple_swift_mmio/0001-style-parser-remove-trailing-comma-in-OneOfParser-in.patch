     } else {
       let inclusiveParser = OneOfParser<Bool>(
         (")", false),
-        ("]", true),
+        ("]", true)
       )
 
       guard
diff --git a/Sources/MMIOMacros/Macros/BitFieldMacro.swift b/Sources/MMIOMacros/Macros/BitFieldMacro.swift
