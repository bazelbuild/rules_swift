From fe7606c89ed47c0da534c488aa8b1db4a7d0b7a4 Mon Sep 17 00:00:00 2001
From: Mathieu Olivari <molivari@apple.com>
Date: Thu, 26 Mar 2026 19:43:38 +0000
Subject: [PATCH] style(parser): remove trailing comma in OneOfParser
 initializer

Commas at the end of lists are only permitted started in 6.1, and
rules_swift CI is still using 6.0.3 on the host machine. So we're
patching swift_mmio until the version is upgraded.
---
 Plugins/SVD2SwiftPlugin/SVD2SwiftPlugin.swift                 | 2 +-
 Sources/MMIOMacros/CompilerPluginMain.swift                   | 2 +-
 Sources/MMIOMacros/Macros/Arguments/BitRange.swift            | 4 ++--
 Sources/MMIOMacros/Macros/BitFieldMacro.swift                 | 2 +-
 .../MMIOMacros/Macros/Descriptions/Description+Validate.swift | 2 +-
 .../MMIOMacros/Macros/Descriptions/RegisterDescription.swift  | 2 +-
 Sources/MMIOMacros/Macros/RegisterBlockMacro.swift            | 2 +-
 Sources/MMIOMacros/Macros/RegisterBlockMemberMacro.swift      | 2 +-
 Sources/MMIOUtilities/Parser/Parser+Swift.swift               | 2 +-
 Sources/XMLMacros/CompilerPluginMain.swift                    | 2 +-
 10 files changed, 11 insertions(+), 11 deletions(-)

diff --git a/Plugins/SVD2SwiftPlugin/SVD2SwiftPlugin.swift b/Plugins/SVD2SwiftPlugin/SVD2SwiftPlugin.swift
index b6007d0..ad66f81 100644
--- a/Plugins/SVD2SwiftPlugin/SVD2SwiftPlugin.swift
+++ b/Plugins/SVD2SwiftPlugin/SVD2SwiftPlugin.swift
@@ -53,7 +53,7 @@ struct SVD2SwiftPlugin: BuildToolPlugin {
     var arguments = [
       "--plugin",
       "--input", svdFile.path,
-      "--output", outputDirectory.path,
+      "--output", outputDirectory.path
     ]
     if let accessLevel = pluginConfig.accessLevel {
       arguments += ["--access-level", accessLevel]
