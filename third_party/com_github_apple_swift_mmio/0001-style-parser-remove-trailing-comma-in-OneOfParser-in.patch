index 21cbbf4..12e0f19 100644
--- a/Sources/MMIOMacros/CompilerPluginMain.swift
+++ b/Sources/MMIOMacros/CompilerPluginMain.swift
@@ -24,6 +24,6 @@ struct CompilerPluginMain: CompilerPlugin {
     ReservedMacro.self,
     ReadWriteMacro.self,
     ReadOnlyMacro.self,
-    WriteOnlyMacro.self,
+    WriteOnlyMacro.self
   ]
 }
diff --git a/Sources/MMIOMacros/Macros/Arguments/BitRange.swift b/Sources/MMIOMacros/Macros/Arguments/BitRange.swift
index 69fee54..1495a09 100644
--- a/Sources/MMIOMacros/Macros/Arguments/BitRange.swift
+++ b/Sources/MMIOMacros/Macros/Arguments/BitRange.swift
